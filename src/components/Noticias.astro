---
import { getCollection } from 'astro:content';

const noticias = (await getCollection('noticias', (e) => e.data.published !== false))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmtFecha = (d) =>
  new Intl.DateTimeFormat('es-MX', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
---

{noticias.length > 0 && (
  <section id="noticias" class="py-16 sm:py-24 bg-gray-bg">
    <div class="max-w-[1310px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-primary text-xs font-semibold uppercase tracking-[0.2em] mb-2">Novedades</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-dark">Noticias y promociones</h2>
        <div class="w-12 h-1 bg-primary mx-auto mt-4 rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {noticias.map((n) => (
          <a
            href={`/noticias/${n.id}`}
            class="card-hover bg-white rounded-lg overflow-hidden border border-border group flex flex-col"
          >
            {n.data.image && (
              <div class="aspect-[16/9] overflow-hidden">
                <img src={n.data.image} alt={n.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
            )}
            <div class="p-5 flex flex-col flex-1">
              <p class="text-text-light text-xs uppercase tracking-wider mb-2">{fmtFecha(n.data.date)}</p>
              <h3 class="text-lg font-bold text-dark group-hover:text-primary transition-colors duration-200">{n.data.title}</h3>
              {n.data.resumen && <p class="text-text-light text-sm mt-2 flex-1">{n.data.resumen}</p>}
              <span class="text-xs font-semibold text-primary hover:text-primary-dark uppercase tracking-wider mt-4">Leer más &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
