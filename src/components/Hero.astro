---
import { marked } from 'marked';
import hero from '../data/hero.json';

// Permite formato (negritas, cursivas, enlaces) en el subtítulo sin envolverlo en <p>
const subtituloHtml = marked.parseInline(hero.subtitulo);

// Imagen de fondo editable desde el CMS (con respaldo por si falta)
const imagenFondo = hero.imagenFondo || '/Hero.jpg';
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden bg-navy">
  <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${imagenFondo}')`}></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/70 to-black/50"></div>

  <div class="relative z-10 max-w-[1310px] mx-auto px-4 sm:px-6 lg:px-8 w-full py-32 sm:py-40">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm text-white text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded-full mb-6">
        <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
        {hero.badge}
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white leading-tight">
        {hero.titulo}
        <span class="text-primary">{hero.tituloResaltado}</span>
      </h1>

      <p class="text-white/70 text-lg sm:text-xl mt-6 leading-relaxed max-w-lg" set:html={subtituloHtml}></p>

      <div class="flex flex-wrap gap-4 mt-8">
        <a
          href="#espacios"
          class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white font-semibold text-sm uppercase tracking-wider rounded hover:bg-primary-dark transition-colors duration-200"
        >
          Ver espacios
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="#tour"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white/10 backdrop-blur-sm text-white border border-white/30 font-semibold text-sm uppercase tracking-wider rounded hover:bg-white/20 transition-all duration-200"
        >
          Tour virtual 360&deg;
        </a>
      </div>
    </div>

    <div class="mt-16 flex flex-wrap gap-8">
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 rounded-lg bg-primary/20 flex items-center justify-center">
          <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold text-white">{hero.statAreaValor}</p>
          <p class="text-white/50 text-xs uppercase tracking-wider">{hero.statAreaLabel}</p>
        </div>
      </div>
      <div class="w-px h-12 bg-white/20 hidden sm:block"></div>
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 rounded-lg bg-secondary/20 flex items-center justify-center">
          <svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016A3.001 3.001 0 0021 9.349m-18 0a2.999 2.999 0 003.397-1.852A3 3 0 007.5 5.25h9a3 3 0 001.103 2.247 2.999 2.999 0 003.397 1.852" />
          </svg>
        </div>
        <div>
          <p class="text-lg font-bold text-white leading-tight">{hero.statCentro}</p>
        </div>
      </div>
      <div class="w-px h-12 bg-white/20 hidden sm:block"></div>
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 rounded-lg bg-white/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold text-white">{hero.statUbicacionValor}</p>
          <p class="text-white/50 text-xs uppercase tracking-wider">{hero.statUbicacionLabel}</p>
        </div>
      </div>
    </div>
  </div>
</section>
