---
import tour from '../data/tour.json';
---

<section id="tour" class="py-16 sm:py-24 bg-gray-bg">
  <div class="max-w-[1310px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <p class="text-primary text-xs font-semibold uppercase tracking-[0.2em] mb-2">{tour.etiqueta}</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-dark">
        {tour.titulo}
      </h2>
      <div class="w-12 h-1 bg-primary mx-auto mt-4 rounded-full"></div>
      <p class="text-text-light text-base mt-4 max-w-xl mx-auto">
        {tour.subtitulo}
      </p>
    </div>

    <div class="rounded-lg overflow-hidden border border-border shadow-lg bg-white relative" style="height: 500px;">
      <div id="panorama" class="w-full h-full hidden"></div>

      <div id="tour-placeholder" class="absolute inset-0 cursor-pointer group" style="background-color: #334c0a;">
        <img id="placeholder-img" src={tour.vistas[0].img} alt="Vista previa" class="w-full h-full object-cover opacity-50" />
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-3">
          <div class="w-16 h-16 rounded-full bg-white/20 border-2 border-white flex items-center justify-center group-hover:bg-white/30 transition-all duration-300">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <span class="text-white font-semibold text-sm uppercase tracking-wider">Ver en 360°</span>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-center gap-4 mt-5">
      <button id="prev-scene" class="w-9 h-9 rounded-full border border-border bg-white flex items-center justify-center hover:border-primary hover:text-primary transition-all duration-200 text-dark">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <span id="scene-label" class="text-text-light text-xs font-semibold uppercase tracking-wider min-w-[80px] text-center">Vista 1</span>
      <button id="next-scene" class="w-9 h-9 rounded-full border border-border bg-white flex items-center justify-center hover:border-primary hover:text-primary transition-all duration-200 text-dark">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    <div class="grid grid-cols-4 sm:grid-cols-8 gap-2 mt-6" id="thumb-grid">
      {tour.vistas.map((v, i) => (
        <button
          class="thumb-btn relative rounded overflow-hidden border-2 border-transparent hover:border-primary transition-all duration-200 aspect-video bg-dark/10"
          data-index={i}
          data-src={v.img}
        >
          <img src={v.img} alt={v.label} class="w-full h-full object-cover" loading="lazy" />
          <span class="absolute bottom-1 right-1 bg-black/60 text-white text-[10px] font-bold px-1.5 py-0.5 rounded">{i+1}</span>
        </button>
      ))}
    </div>
  </div>
</section>

<script is:inline define:vars={{ vistas: tour.vistas }}>
  var scenes = vistas.map(function (v) { return { image: v.img, label: v.label }; });

  var currentIndex = 0;
  var viewer = null;
  var activated = false;

  function activateViewer(index) {
    activated = true;
    var placeholder = document.getElementById('tour-placeholder');
    var panoramaEl = document.getElementById('panorama');
    if (placeholder) placeholder.style.display = 'none';
    if (panoramaEl) panoramaEl.classList.remove('hidden');
    loadScene(index);
  }

  function loadScene(index) {
    currentIndex = index;
    var scene = scenes[index];
    document.getElementById('scene-label').textContent = scene.label;

    var previewImg = document.getElementById('placeholder-img');
    if (previewImg) previewImg.src = scene.image;

    if (!activated) return;

    if (viewer) { viewer.destroy(); viewer = null; }

    if (typeof pannellum !== 'undefined') {
      viewer = pannellum.viewer('panorama', {
        type: 'equirectangular',
        panorama: scene.image,
        autoLoad: true,
        compass: false,
        showControls: true,
        mouseZoom: true,
        hfov: 110,
        pitch: 0,
        yaw: 0,
      });
    }

    document.querySelectorAll('.thumb-btn').forEach(function(btn) {
      var active = parseInt(btn.getAttribute('data-index')) === index;
      btn.classList.toggle('border-primary', active);
      btn.classList.toggle('border-transparent', !active);
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    var firstThumb = document.querySelector('.thumb-btn[data-index="0"]');
    if (firstThumb) firstThumb.classList.replace('border-transparent', 'border-primary');

    document.getElementById('tour-placeholder').addEventListener('click', function() {
      activateViewer(currentIndex);
    });

    document.querySelectorAll('.thumb-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = parseInt(btn.getAttribute('data-index'));
        if (!activated) {
          activateViewer(idx);
        } else {
          loadScene(idx);
        }
      });
    });

    document.getElementById('prev-scene').addEventListener('click', function() {
      loadScene((currentIndex - 1 + scenes.length) % scenes.length);
    });
    document.getElementById('next-scene').addEventListener('click', function() {
      loadScene((currentIndex + 1) % scenes.length);
    });
  });
</script>
