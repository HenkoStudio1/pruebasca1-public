---
import contacto from '../data/contacto.json';

const waText = encodeURIComponent('Hola, me interesa un espacio en Plaza Paseo del Parque');
const waHref = `https://wa.me/${contacto.whatsapp}?text=${waText}`;
---

<section id="contacto" class="py-16 sm:py-24 bg-navy text-white">
  <div class="max-w-[1310px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-primary text-xs font-semibold uppercase tracking-[0.2em] mb-2">{contacto.etiqueta}</p>
      <h2 class="text-3xl sm:text-4xl font-bold">
        {contacto.tituloInicio}<span class="text-primary">{contacto.tituloResaltado}</span>{contacto.tituloFin}
      </h2>
      <div class="w-12 h-1 bg-primary mx-auto mt-4 rounded-full"></div>
    </div>

    <div class="grid lg:grid-cols-5 gap-10 lg:gap-16">
      <div class="lg:col-span-2">
        <p class="text-white/70 text-base leading-relaxed">
          {contacto.intro}
        </p>

        <div class="space-y-4 mt-8">
          <a
            href={waHref}
            target="_blank"
            rel="noopener"
            class="flex items-center gap-4 bg-white/5 border border-white/10 rounded-lg p-4 hover:bg-whatsapp/10 hover:border-whatsapp/30 transition-all duration-200 group"
          >
            <div class="w-12 h-12 rounded-lg bg-whatsapp flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-sm group-hover:text-whatsapp transition-colors">Escribir por WhatsApp</p>
              <p class="text-white/50 text-xs mt-0.5">Respuesta inmediata</p>
            </div>
            <span class="relative flex h-3 w-3 ml-auto">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-whatsapp/50"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-whatsapp"></span>
            </span>
          </a>

          <div class="flex items-center gap-4 bg-white/5 border border-white/10 rounded-lg p-4">
            <div class="w-12 h-12 rounded-lg bg-primary/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-sm">{contacto.telefono}</p>
              <p class="text-white/50 text-xs mt-0.5">{contacto.horario}</p>
            </div>
          </div>

          <div class="flex items-center gap-4 bg-white/5 border border-white/10 rounded-lg p-4">
            <div class="w-12 h-12 rounded-lg bg-primary/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-sm">{contacto.email}</p>
              <p class="text-white/50 text-xs mt-0.5">Escríbenos un correo</p>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-3">
        <div class="bg-white rounded-lg p-6 sm:p-8">
          <form id="contact-form" class="space-y-5" novalidate>
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="nombre" class="block text-xs font-semibold text-dark uppercase tracking-wider mb-1.5">Nombre *</label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  class="w-full bg-gray-bg border border-border rounded px-4 py-3 text-dark text-sm placeholder-text-muted focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all duration-200"
                  placeholder="Tu nombre completo"
                />
              </div>
              <div>
                <label for="empresa" class="block text-xs font-semibold text-dark uppercase tracking-wider mb-1.5">Empresa</label>
                <input
                  type="text"
                  id="empresa"
                  name="empresa"
                  class="w-full bg-gray-bg border border-border rounded px-4 py-3 text-dark text-sm placeholder-text-muted focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all duration-200"
                  placeholder="Nombre de tu empresa"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="correo" class="block text-xs font-semibold text-dark uppercase tracking-wider mb-1.5">Correo electrónico *</label>
                <input
                  type="email"
                  id="correo"
                  name="correo"
                  required
                  class="w-full bg-gray-bg border border-border rounded px-4 py-3 text-dark text-sm placeholder-text-muted focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all duration-200"
                  placeholder="correo@ejemplo.com"
                />
              </div>
              <div>
                <label for="giro" class="block text-xs font-semibold text-dark uppercase tracking-wider mb-1.5">Giro de negocio</label>
                <input
                  type="text"
                  id="giro"
                  name="giro"
                  class="w-full bg-gray-bg border border-border rounded px-4 py-3 text-dark text-sm placeholder-text-muted focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all duration-200"
                  placeholder="Ej: Restaurante, consultorio"
                />
              </div>
            </div>

            <div>
              <label for="mensaje" class="block text-xs font-semibold text-dark uppercase tracking-wider mb-1.5">Mensaje</label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="4"
                class="w-full bg-gray-bg border border-border rounded px-4 py-3 text-dark text-sm placeholder-text-muted focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all duration-200 resize-none"
                placeholder="¿Qué espacio te interesa? ¿Alguna pregunta?"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-primary text-white font-semibold py-3.5 rounded hover:bg-primary-dark transition-colors duration-200 text-sm uppercase tracking-wider"
            >
              Enviar mensaje
            </button>
          </form>

          <div id="form-success" class="hidden text-center py-12">
            <div class="w-16 h-16 rounded-full bg-secondary/20 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-2">Mensaje enviado</h3>
            <p class="text-text-light text-sm">Nos pondremos en contacto contigo pronto.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ waNumber: contacto.whatsapp }}>
  document.getElementById('contact-form').addEventListener('submit', function(e) {
    e.preventDefault();

    var nombre  = document.getElementById('nombre').value.trim();
    var empresa = document.getElementById('empresa').value.trim();
    var correo  = document.getElementById('correo').value.trim();
    var giro    = document.getElementById('giro').value.trim();
    var mensaje = document.getElementById('mensaje').value.trim();

    var nombreInput = document.getElementById('nombre');
    var correoInput = document.getElementById('correo');
    var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    var valid = true;

    if (!nombre) {
      nombreInput.style.borderColor = '#ef4444';
      valid = false;
    } else {
      nombreInput.style.borderColor = '';
    }

    if (!correo || !emailRegex.test(correo)) {
      correoInput.style.borderColor = '#ef4444';
      valid = false;
    } else {
      correoInput.style.borderColor = '';
    }

    if (!valid) return;

    var text = 'Hola, me interesa un espacio en Plaza Paseo del Parque.\n\n';
    text += '*Nombre:* ' + nombre + '\n';
    if (empresa) text += '*Empresa:* ' + empresa + '\n';
    text += '*Correo:* ' + correo + '\n';
    if (giro)    text += '*Giro:* ' + giro + '\n';
    if (mensaje) text += '\n' + mensaje;

    var a = document.createElement('a');
    a.href = 'https://wa.me/' + waNumber + '?text=' + encodeURIComponent(text);
    a.target = '_blank';
    a.rel = 'noopener noreferrer';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);

    document.getElementById('contact-form').classList.add('hidden');
    document.getElementById('form-success').classList.remove('hidden');
  });
</script>
