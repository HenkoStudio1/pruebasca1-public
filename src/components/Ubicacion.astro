---
import contacto from '../data/contacto.json';
import ubicacion from '../data/ubicacion.json';
const direccionLineas = contacto.direccion.split('\n');
const landmarks = ubicacion.puntos;
---

<section id="ubicacion" class="py-16 sm:py-24 bg-white">
  <div class="max-w-[1310px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <p class="text-primary text-xs font-semibold uppercase tracking-[0.2em] mb-2">{ubicacion.etiqueta}</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-dark">
        {ubicacion.titulo}
      </h2>
      <div class="w-12 h-1 bg-primary mx-auto mt-4 rounded-full"></div>
    </div>

    <div class="grid lg:grid-cols-5 gap-8 items-start">
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-gray-bg rounded-lg p-6 border border-border">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-dark text-sm mb-1">Dirección</h3>
              <p class="text-text-light text-sm leading-relaxed">
                {direccionLineas.map((linea, i) => (
                  <>{i > 0 && <br />}{linea}</>
                ))}
              </p>
            </div>
          </div>
        </div>

        <div class="bg-gray-bg rounded-lg p-6 border border-border">
          <h3 class="font-bold text-dark text-sm mb-4">Puntos cercanos</h3>
          <ul class="space-y-3">
            {landmarks.map((l) => (
              <li class="flex items-center justify-between text-sm">
                <div class="flex items-center gap-2 text-text-light">
                  <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
                  </svg>
                  {l.name}
                </div>
                <span class="text-primary font-semibold text-xs bg-primary/10 px-2 py-0.5 rounded">{l.time}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="lg:col-span-3 rounded-lg overflow-hidden border border-border shadow-sm">
        <iframe
          src={ubicacion.mapaUrl}
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Plaza Paseo del Parque"
        ></iframe>
      </div>
    </div>
  </div>
</section>
