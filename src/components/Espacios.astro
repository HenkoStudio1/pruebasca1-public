---
import data from '../data/espacios.json';
const espacios = data.items
  .filter((e) => e.visible !== false)
  .map((e) => ({
    ...e,
    badge: e.tipo === 'Oficina' ? 'bg-secondary' : 'bg-primary',
  }));
---

<section id="espacios" class="py-16 sm:py-24 bg-gray-bg">
  <div class="max-w-[1310px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-primary text-xs font-semibold uppercase tracking-[0.2em] mb-2">{data.etiqueta}</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-dark">
        {data.titulo}
      </h2>
      <div class="w-12 h-1 bg-primary mx-auto mt-4 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {espacios.map((espacio) => (
        <div class="card-hover bg-white rounded-lg overflow-hidden border border-border group">
          <div class="relative img-zoom">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={espacio.img} alt={espacio.nombre} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <span class={`absolute top-3 left-3 text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded ${espacio.status === 'Destacado' ? 'bg-[#dd3333]' : 'bg-secondary'}`}>
              {espacio.status}
            </span>
            <span class={`absolute top-3 right-3 text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded ${espacio.badge}`}>
              {espacio.tipo}
            </span>
          </div>

          <div class="p-5">
            <h3 class="text-lg font-bold text-dark group-hover:text-primary transition-colors duration-200">{espacio.nombre}</h3>
            <p class="text-text-light text-sm mt-0.5 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
              </svg>
              {espacio.ubicacion}
            </p>

            <div class="flex items-center gap-4 mt-4 pt-4 border-t border-border">
              <div class="flex items-center gap-1.5 text-text-light text-sm">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
                </svg>
                <span class="font-semibold text-dark">{espacio.metros} m&sup2;</span>
              </div>
            </div>

            <div class="mt-4 flex items-center justify-between">
              <span class="text-primary font-bold text-lg">{espacio.precio}</span>
              <a href="#contacto" class="text-xs font-semibold text-primary hover:text-primary-dark uppercase tracking-wider transition-colors">
                Info &rarr;
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
