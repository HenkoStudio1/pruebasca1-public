---
import video from '../data/video.json';
---
<section class="bg-black py-16 sm:py-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">{video.titulo}</h2>
      <p class="text-gray-400 text-lg">{video.subtitulo}</p>
    </div>

    <div class="relative rounded-2xl overflow-hidden shadow-2xl ring-1 ring-white/10">
      <!-- 16:9 wrapper -->
      <div class="relative w-full" style="padding-bottom: 56.25%;">
        <div id="yt-player" class="absolute inset-0 w-full h-full"></div>

        <!-- Custom play/pause overlay (shown when paused) -->
        <div
          id="video-overlay"
          class="absolute inset-0 flex items-center justify-center cursor-pointer transition-opacity duration-300"
          style="opacity: 0; pointer-events: none;"
        >
          <button
            id="toggle-btn"
            class="w-20 h-20 rounded-full bg-black/50 backdrop-blur-sm border border-white/30 flex items-center justify-center hover:bg-black/70 hover:scale-105 transition-all duration-200"
            aria-label="Play / Pause"
          >
            <!-- Play icon -->
            <svg id="icon-play" class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <!-- Pause icon -->
            <svg id="icon-pause" class="w-8 h-8 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

  </div>
</section>

<script is:inline define:vars={{ ytId: video.youtubeId }}>
(function () {
  // Load YouTube IFrame API
  var tag = document.createElement('script');
  tag.src = 'https://www.youtube.com/iframe_api';
  var first = document.getElementsByTagName('script')[0];
  first.parentNode.insertBefore(tag, first);

  var player;
  var overlay   = document.getElementById('video-overlay');
  var iconPlay  = document.getElementById('icon-play');
  var iconPause = document.getElementById('icon-pause');
  var toggleBtn = document.getElementById('toggle-btn');

  window.onYouTubeIframeAPIReady = function () {
    player = new YT.Player('yt-player', {
      videoId: ytId,
      playerVars: {
        autoplay: 1,
        mute: 1,
        controls: 0,
        modestbranding: 1,
        rel: 0,
        loop: 1,
        playlist: ytId,
        playsinline: 1,
        disablekb: 1,
        fs: 0
      },
      events: {
        onStateChange: function (e) {
          // YT.PlayerState: PLAYING = 1, PAUSED = 2
          if (e.data === 1) {
            // Playing — hide overlay
            overlay.style.opacity = '0';
            overlay.style.pointerEvents = 'none';
            iconPlay.classList.add('hidden');
            iconPause.classList.remove('hidden');
          } else if (e.data === 2 || e.data === 0) {
            // Paused or ended — show overlay
            overlay.style.opacity = '1';
            overlay.style.pointerEvents = 'auto';
            iconPlay.classList.remove('hidden');
            iconPause.classList.add('hidden');
          }
        }
      }
    });
  };

  // Toggle on overlay click
  document.getElementById('video-overlay').addEventListener('click', function () {
    if (!player) return;
    var state = player.getPlayerState();
    if (state === 1) {
      player.pauseVideo();
    } else {
      player.playVideo();
    }
  });
})();
</script>
