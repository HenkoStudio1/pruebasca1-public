---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('noticias', (e) => e.data.published !== false);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const fmtFecha = (d) =>
  new Intl.DateTimeFormat('es-MX', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
---

<Layout title={`${entry.data.title} — Plaza Paseo del Parque`} description={entry.data.resumen}>
  <article class="pt-28 pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/#noticias" class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary-dark mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Volver a noticias
      </a>

      <p class="text-text-light text-xs uppercase tracking-wider mb-2">{fmtFecha(entry.data.date)}</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-dark leading-tight">{entry.data.title}</h1>

      {entry.data.image && (
        <div class="rounded-lg overflow-hidden border border-border mt-8">
          <img src={entry.data.image} alt={entry.data.title} class="w-full h-auto object-cover" />
        </div>
      )}

      <div class="prose-noticia mt-8 text-text-light leading-relaxed space-y-4">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .prose-noticia :global(h2) { font-size: 1.5rem; font-weight: 700; color: var(--color-dark, #1a1a1a); margin-top: 1.5rem; }
  .prose-noticia :global(h3) { font-size: 1.25rem; font-weight: 700; color: var(--color-dark, #1a1a1a); margin-top: 1.25rem; }
  .prose-noticia :global(a) { color: #334c0a; text-decoration: underline; }
  .prose-noticia :global(ul) { list-style: disc; padding-left: 1.25rem; }
  .prose-noticia :global(img) { border-radius: 0.5rem; }
</style>
